# comment


/a"main"/
/world"foobar[a-z\"]"/

TOKEN<b, a> {
  a: a.1.2.c;
  a: b;
  vector: ("a" + b) * 1 , hello;
  event {
    "hello."+"world": "hello world";
    a.n: c.b;
  }
  OPERATIONS: -A + B / 1 - C * 2 ** 3 ** 4;
  A: ++A--;
}

